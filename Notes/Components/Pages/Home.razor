@page "/"
@rendermode InteractiveServer

<div class="container">
	<div class="row">
		<div class="col text-center">
			<h1>Welcome to Home page</h1>
		</div>
	</div>
</div>

<div class="container">
	<div class="row">
		<div class="col text-center">
			<h2>Show all games in Database:</h2>
		</div>
	</div>
</div>

<GamesTable Games="games"/>

<OneGame Game="games[0]" IsTable="false" DisplayButton="true"/>

@code
{
	private List<Game>? games;

	protected override void OnInitialized()
	{
		games = new List<Game>
		{
			new Game()
			{
				Name = "Cities SkyLine",
				Genre = "Simulator",
				ReleaseDate = new DateTime(2013, 10, 15)
			},
			new Game()
			{
				Name = "The Witcher 3",
				Genre = "Action/RPG",
				ReleaseDate = new DateTime(2016, 05, 18)
			},
			new Game()
			{
				Name = "They are billion!",
				Genre = "Strategy",
				ReleaseDate = new DateTime(2019, 03, 10)
			}
		};
	}
}